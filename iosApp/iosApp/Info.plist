<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!-- Dev only: allow cleartext HTTP to private/local network (Mac LAN IP, localhost). Prod uses https. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- Register the inclinic:// URL scheme so the OS routes deep links to this app. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.inclinic.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>inclinic</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
